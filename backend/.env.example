# Configurações da API
API_V1_STR=/api/v1
PROJECT_NAME=papprefeito API

# Ambiente / Segurança
ENVIRONMENT=development
DEBUG=true
# Gere uma chave forte: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-uma-chave-aleatoria-forte

# CORS (em produção, especificar domínios específicos — NÃO usar "*")
ALLOWED_HOSTS=["https://maispap.dasix.site","https://api-maispap.dasix.site"]

# API Externa
SAUDE_API_BASE_URL=https://relatorioaps-prd.saude.gov.br/financiamento/pagamento
SAUDE_API_TIMEOUT=30

# Cache Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost/papprefeito

# Arquivos JSON (compatibilidade)
DATA_CACHE_FILE=data_cache_papprefeito.json
EDITED_DATA_FILE=municipios_editados.json

# Appwrite Configuration
# Obtenha sua API Key no console do Appwrite (Settings do projeto)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=seu_project_id_aqui
APPWRITE_API_KEY=sua_api_key_secreta_aqui
APPWRITE_DATABASE_ID=papprefeito_db
APPWRITE_COLLECTION_EDICOES_ID=edicoes_municipios

# Paginação
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100